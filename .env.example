# ──────────────────────────────────────────────────────────────
# Server — copy to .env and fill in real values
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection string (required)
# Local:  postgresql://user:password@localhost:5432/dbname
# Neon:   postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic API key — required for the PCB (Podcast Content Browser) feature
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key — optional, enables Gemini as an alternative AI provider for transcript analysis
GEMINI_API_KEY=

# Supadata API key — required for YouTube transcript extraction (supadata.ai)
SUPADATA_API_KEY=

# Port the Express server listens on (default: 5000)
PORT=5000

# ──────────────────────────────────────────────────────────────
# Client (Vite) — prefix with VITE_ so Vite exposes them to the browser
# ──────────────────────────────────────────────────────────────

# Full URL of the API server.  Leave empty for local dev (Vite proxy handles it).
# In production (Netlify), set this to your Render backend URL.
# Example: https://media-navigator.onrender.com
VITE_API_URL=
